# Copy this file to .env and fill it in with the values printed by
# scripts/setup-aws.sh. .env is in .gitignore: NEVER commit credentials.
#
# With no variables set the app still starts in "memory mode": records live in
# RAM and the status panel makes it clear.

AWS_REGION=eu-west-1
DYNAMODB_TABLE=vedtemplate-app
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: origins (comma-separated) allowed to call the API from another
# domain. Unset = same-origin (production and local dev).
# CORS_ORIGINS=http://localhost:3000

# Optional: point at DynamoDB Local for integration tests.
# DYNAMODB_ENDPOINT=http://localhost:8000

# Optional: salt for hashing IPs in the traffic monitoring. Setting your own
# value in production makes the hash→IP association irreversible. If unset, a
# default value is used (good enough for the demo).
# TRACK_SALT=change-this-for-a-random-string
