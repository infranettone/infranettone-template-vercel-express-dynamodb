# Copia este archivo a .env y rellénalo con los valores que imprime
# scripts/setup-aws.sh. El .env está en .gitignore: NUNCA subas credenciales.
#
# Sin ninguna variable la app arranca igualmente en "modo memoria": los
# registros viven en RAM y el panel de estado lo indica claramente.

AWS_REGION=eu-west-1
DYNAMODB_TABLE=vedtemplate-app
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Opcional: orígenes (separados por comas) autorizados a llamar a la API
# desde otro dominio. Sin definir = same-origin (producción y dev local).
# CORS_ORIGINS=http://localhost:3000

# Opcional: apuntar a DynamoDB Local para tests de integración.
# DYNAMODB_ENDPOINT=http://localhost:8000
